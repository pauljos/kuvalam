# AXON API Environment Variables - Template Configuration
# Copy this file to .env or .env.local and configure details

# Server Port
PORT=3001
NODE_ENV=development

# Database Connection (PostgreSQL with pgvector enabled)
DATABASE_URL=postgresql://axon:axon_dev_password@localhost:5434/axon_db

# Redis Connection (For BullMQ Job Queues & Caching)
REDIS_URL=redis://localhost:6380

# Security Keys
# JWT Token Secret Key (Must be changed in production)
JWT_SECRET=axon-dev-secret-change-in-production

# Credential Encryption Key (Must be exactly 32 bytes/characters for AES-256-GCM)
CREDENTIAL_ENCRYPTION_KEY=my_secure_super_secret_key_32_c

# SMTP E-Mail configuration
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@axon.ai

# Frontend URL (For OAuth callbacks / CORS validation)
FRONTEND_URL=http://localhost:3000
