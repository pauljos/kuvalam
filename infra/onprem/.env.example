# =============================================================================
# Kuvalam — On-Prem Configuration
# =============================================================================
# Copy this file to .env in the same directory and edit the values below.
# All values marked REQUIRED must be set. Others have sensible defaults.
#
# The install.sh script will generate secrets automatically the first time —
# you only need to fill in ADMIN_* and TENANT_* if you plan to run install.sh
# non-interactively.
# =============================================================================

# ── Networking ───────────────────────────────────────────────────────────────
# Where the web UI is reachable from users' browsers on the local network.
# Example: http://kuvalam.acme.local  |  http://192.168.1.50:3000
# REQUIRED
NEXT_PUBLIC_API_URL=http://192.168.1.50:3001
FRONTEND_URL=http://192.168.1.50:3000

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=kuvalam
POSTGRES_DB=kuvalam_db
# REQUIRED — will be generated by install.sh if left blank
POSTGRES_PASSWORD=

# ── Application secrets ──────────────────────────────────────────────────────
# All three must be at least 32 random characters. install.sh generates these
# with `openssl rand -hex 32` on first run.
JWT_SECRET=
COOKIE_SECRET=
# CREDENTIAL_ENCRYPTION_KEY is used to encrypt LLM API keys, connector tokens,
# and DB connector passwords at rest. NEVER change this after data is stored —
# existing encrypted rows will become undecryptable.
CREDENTIAL_ENCRYPTION_KEY=

# ── First-run admin ──────────────────────────────────────────────────────────
# Used by install.sh to create the first OWNER user and tenant. After the
# install completes you can clear these values or delete the .env entirely
# (secrets above still needed for the containers to start).
ADMIN_EMAIL=admin@acme.local
ADMIN_PASSWORD=
ADMIN_NAME=Administrator
TENANT_NAME=Acme Corp
TENANT_SLUG=acme

# ── Worker throughput ────────────────────────────────────────────────────────
TASK_CONCURRENCY=5
WORKFLOW_CONCURRENCY=3
WORKER_REPLICAS=1

# ── Optional: Object storage (S3-compatible) ─────────────────────────────────
# Leave blank to store uploaded files on the local disk (mapped as a Docker volume).
# For a self-hosted MinIO you can also point at that.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# ── Optional: SMTP for outbound email ────────────────────────────────────────
# Leave blank if you don't need password-reset emails etc. On-prem installs
# often use a local relay like Postfix on the host or an office SMTP gateway.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── LLM providers ────────────────────────────────────────────────────────────
# You do NOT set LLM API keys here — they are configured per-tenant in the
# Settings UI (encrypted at rest with CREDENTIAL_ENCRYPTION_KEY).
#
# For local-network LLMs, users pick "Ollama (Local)", "LM Studio (Local)",
# "LocalAI (Local)" or "Custom OpenAI-Compatible" in Settings and enter the
# Base URL of their inference server (e.g. http://192.168.1.60:11434/v1).
#
# The optional OPENAI_API_KEY / ANTHROPIC_API_KEY vars below are ONLY used as
# a system-wide fallback for the internal knowledge-embedding pipeline in
# tenants that have not configured a provider yet. Leave blank if you want a
# fully-local install.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
