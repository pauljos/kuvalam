# .env.example — copy to .env and fill in values before deploying
# NEVER commit .env to git

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=kuvalam
POSTGRES_PASSWORD=change_me_strong_password_here
POSTGRES_DB=kuvalam_db

# ── Application Secrets ───────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=
COOKIE_SECRET=
CREDENTIAL_ENCRYPTION_KEY=        # Must be at least 32 characters

# ── URLs ──────────────────────────────────────────────────────────────────────
# The public URL your API is reachable at (from the browser)
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
# The origin of your web frontend (used by API for CORS)
FRONTEND_URL=https://app.yourdomain.com

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379          # or redis://:password@host:6379 for managed Redis

# ── LLM Providers (add whichever you use) ────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=

# ── S3-Compatible Storage ─────────────────────────────────────────────────────
# Leave blank to use local disk (not suitable for multi-instance deployments)
AWS_REGION=eu-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=kuvalam-documents

# ── Email / SMTP ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# ── Worker Tuning ─────────────────────────────────────────────────────────────
TASK_CONCURRENCY=5
WORKFLOW_CONCURRENCY=3
TASK_RATE_LIMIT=20                    # Max agent task dispatches per tenant per minute
WORKER_REPLICAS=1                     # Scale to 2+ for high workloads

# ── OAuth Provider Credentials ───────────────────────────────────────────────
# Register apps at each provider's developer console and paste IDs/secrets here
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
